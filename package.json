{
  "name": "openhinge",
  "version": "0.1.0",
  "description": "Self-hosted AI gateway — multi-provider, multi-tenant, soul-based routing",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "openhinge": "./dist/bin/openhinge.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openhinge/openhinge.git"
  },
  "homepage": "https://github.com/openhinge/openhinge",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json; cp -r src/db/migrations dist/src/db/migrations; chmod +x dist/bin/openhinge.js",
    "start": "node dist/src/index.js",
    "cli": "tsx bin/openhinge.ts",
    "test": "vitest",
    "migrate": "tsx bin/openhinge.ts migrate"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/static": "^8.1.0",
    "@fastify/cors": "^10.0.3",
    "better-sqlite3": "^11.9.1",
    "zod": "^3.25.3",
    "commander": "^13.1.0",
    "cron": "^4.3.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "nanoid": "^5.1.5",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "vitest": "^3.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21"
  }
}
