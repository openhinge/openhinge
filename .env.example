OPENHINGE_PORT=3700
OPENHINGE_HOST=127.0.0.1
OPENHINGE_ADMIN_TOKEN=change-me-to-a-long-random-string
OPENHINGE_ENCRYPTION_KEY=change-me-32-chars-minimum-random
OPENHINGE_DB_PATH=./data/openhinge.db
OPENHINGE_LOG_LEVEL=info

# Google OAuth (for Gemini provider login)
GEMINI_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GEMINI_OAUTH_CLIENT_SECRET=your-google-client-secret
